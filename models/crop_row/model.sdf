    </visual>

    <visual name="panicle_top">

      <pose>0 0 0.97 0 0 0</pose>

      <geometry>
        <sphere>
          <radius>0.045</radius>
        </sphere>
      </geometry>

      <material>
        <ambient>0.70 0.60 0.30 1</ambient>

<?xml version="1.0"?>
<sdf version="1.7">
  <model name="bird_reflective_spinner">
    <!-- Ground-mounted base plate for structural stability. -->
    <link name="base_plate">
      <pose>0 0 0.12 0 0 0</pose>
      <inertial>
        <mass>10.0</mass>
        <inertia>
          <ixx>0.25</ixx>
          <iyy>0.25</iyy>
          <izz>0.18</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="plate_collision">
        <geometry>
          <box>
            <size>0.60 0.60 0.24</size>
          </box>
        </geometry>
      </collision>

      <visual name="plate_visual">
        <geometry>
          <box>
            <size>0.60 0.60 0.24</size>
          </box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.4 0.4 0.4 1.0</diffuse>
          <specular>0.15 0.15 0.15 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Central vertical pole anchored to the base plate. -->
    <link name="central_pole">
      <pose>0 0 0.95 0 0 0</pose>
      <inertial>
        <mass>3.5</mass>
        <inertia>
          <ixx>0.04</ixx>
          <iyy>0.04</iyy>
          <izz>0.008</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="pole_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>1.90</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="pole_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>1.90</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.45 0.45 0.45 1.0</ambient>
          <diffuse>0.55 0.55 0.55 1.0</diffuse>
          <specular>0.2 0.2 0.2 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- First rotating disc positioned at lower height on the pole. -->
    <link name="spinner_disc_lower">
      <pose>0.20 0 0.65 0 0 0</pose>
      <inertial>
        <mass>0.6</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="disc_lower_collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="disc_lower_visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.9 1.0</ambient>
          <diffuse>1.0 1.0 1.0 1.0</diffuse>
          <specular>0.8 0.8 0.8 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Second rotating disc positioned at middle height on the pole. -->
    <link name="spinner_disc_middle">
      <pose>-0.20 0 1.25 0 0 0</pose>
      <inertial>
        <mass>0.6</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="disc_middle_collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="disc_middle_visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.9 1.0</ambient>
          <diffuse>1.0 1.0 1.0 1.0</diffuse>
          <specular>0.8 0.8 0.8 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Third rotating disc positioned at upper height on the pole. -->
    <link name="spinner_disc_upper">
      <pose>0.20 0 1.85 0 0 0</pose>
      <inertial>
        <mass>0.6</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="disc_upper_collision">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="disc_upper_visual">
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.9 1.0</ambient>
          <diffuse>1.0 1.0 1.0 1.0</diffuse>
          <specular>0.8 0.8 0.8 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Fixed joint connecting base plate to central pole. -->
    <joint name="base_to_pole_joint" type="fixed">
      <parent>base_plate</parent>
      <child>central_pole</child>
      <pose>0 0 -0.71 0 0 0</pose>
    </joint>

    <!-- Continuous revolute joint rotating the lower disc around the pole (Z-axis). -->
    <joint name="pole_to_disc_lower_joint" type="revolute">
      <parent>central_pole</parent>
      <child>spinner_disc_lower</child>
      <pose>0 0 0.3 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265</lower>
          <upper>3.14159265</upper>
          <effort>8.0</effort>
          <velocity>3.0</velocity>
        </limit>
      </axis>
      <dynamics>
        <friction>0.3</friction>
        <damping>0.05</damping>
        <spring_reference>0</spring_reference>
        <spring_stiffness>0</spring_stiffness>
      </dynamics>
    </joint>

    <!-- Continuous revolute joint rotating the middle disc around the pole (Z-axis). -->
    <joint name="pole_to_disc_middle_joint" type="revolute">
      <parent>central_pole</parent>
      <child>spinner_disc_middle</child>
      <pose>0 0 0.3 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265</lower>
          <upper>3.14159265</upper>
          <effort>8.0</effort>
          <velocity>3.0</velocity>
        </limit>
      </axis>
      <dynamics>
        <friction>0.3</friction>
        <damping>0.05</damping>
        <spring_reference>0</spring_reference>
        <spring_stiffness>0</spring_stiffness>
      </dynamics>
    </joint>

    <!-- Continuous revolute joint rotating the upper disc around the pole (Z-axis). -->
    <joint name="pole_to_disc_upper_joint" type="revolute">
      <parent>central_pole</parent>
      <child>spinner_disc_upper</child>
      <pose>0 0 0.3 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265</lower>
          <upper>3.14159265</upper>
          <effort>8.0</effort>
          <velocity>3.0</velocity>
        </limit>
      </axis>
      <dynamics>
        <friction>0.3</friction>
        <damping>0.05</damping>
        <spring_reference>0</spring_reference>
        <spring_stiffness>0</spring_stiffness>
      </dynamics>
    </joint>
  </model>
</sdf>

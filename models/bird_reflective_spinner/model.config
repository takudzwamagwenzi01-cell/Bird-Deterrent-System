<?xml version="1.0"?>
<model>
  <name>bird_reflective_spinner</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>Takudzwa Magwenzi</name>
    <email>takudzwamagwenzi01@gmail.com</email>
  </author>

  <description>
    A reflective spinner disc array bird deterrent for Gazebo Classic 11 and ROS 2.
    The model features a mounting base, vertical pole, and multiple rotating reflective discs
    that create light flashes and motion patterns to deter birds from protected areas.
  </description>
</model>

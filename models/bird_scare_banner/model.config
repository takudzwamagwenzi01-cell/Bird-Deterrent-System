<?xml version="1.0"?>
<model>
  <name>bird_scare_banner</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>Takudzwa Magwenzi</name>
    <email>takudzwamagwenzi01@gmail.com</email>
  </author>

  <description>
    A rotating banner-style bird deterrent for Gazebo Classic 11 and ROS 2.
    The model features a fixed support structure and a rotating banner controlled
    by a continuous revolute joint. Ideal for active deterrent simulations.
  </description>
</model>

<?xml version="1.0"?>
<sdf version="1.7">
  <model name="bird_scare_banner">
    <!-- Foundation base that anchors the entire structure. -->
    <link name="foundation_base">
      <pose>0 0 0.20 0 0 0</pose>
      <inertial>
        <mass>12.0</mass>
        <inertia>
          <ixx>0.32</ixx>
          <iyy>0.32</iyy>
          <izz>0.24</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="foundation_collision">
        <geometry>
          <box>
            <size>0.50 0.50 0.40</size>
          </box>
        </geometry>
      </collision>

      <visual name="foundation_visual">
        <geometry>
          <box>
            <size>0.50 0.50 0.40</size>
          </box>
        </geometry>
        <material>
          <ambient>0.40 0.40 0.40 1.0</ambient>
          <diffuse>0.50 0.50 0.50 1.0</diffuse>
          <specular>0.1 0.1 0.1 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Fixed central mast that extends vertically from the foundation. -->
    <link name="central_mast">
      <pose>0 0 1.15 0 0 0</pose>
      <inertial>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.06</ixx>
          <iyy>0.06</iyy>
          <izz>0.01</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="mast_collision">
        <geometry>
          <cylinder>
            <radius>0.06</radius>
            <length>1.50</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="mast_visual">
        <geometry>
          <cylinder>
            <radius>0.06</radius>
            <length>1.50</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.55 0.55 0.55 1.0</ambient>
          <diffuse>0.65 0.65 0.65 1.0</diffuse>
          <specular>0.25 0.25 0.25 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Rotating arm assembly that extends horizontally from the mast. -->
    <link name="rotating_arm">
      <pose>0.30 0 1.90 0 0 0</pose>
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.005</ixx>
          <iyy>0.12</iyy>
          <izz>0.12</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="arm_collision">
        <geometry>
          <box>
            <size>0.60 0.08 0.08</size>
          </box>
        </geometry>
      </collision>

      <visual name="arm_visual">
        <geometry>
          <box>
            <size>0.60 0.08 0.08</size>
          </box>
        </geometry>
        <material>
          <ambient>0.50 0.50 0.50 1.0</ambient>
          <diffuse>0.60 0.60 0.60 1.0</diffuse>
          <specular>0.2 0.2 0.2 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Colored banner attached to the rotating arm for visual deterrent effect. -->
    <link name="banner_panel">
      <pose>0.30 0 2.10 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.012</ixx>
          <iyy>0.008</iyy>
          <izz>0.008</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="banner_collision">
        <geometry>
          <box>
            <size>0.40 0.01 0.50</size>
          </box>
        </geometry>
      </collision>

      <visual name="banner_visual">
        <geometry>
          <box>
            <size>0.40 0.01 0.50</size>
          </box>
        </geometry>
        <material>
          <ambient>0.9 0.7 0.1 1.0</ambient>
          <diffuse>1.0 0.8 0.2 1.0</diffuse>
          <specular>0.3 0.3 0.3 1.0</specular>
        </material>
      </visual>
    </link>

    <!-- Fixed joint anchoring the foundation to the central mast. -->
    <joint name="foundation_to_mast_joint" type="fixed">
      <parent>foundation_base</parent>
      <child>central_mast</child>
      <pose>0 0 -0.85 0 0 0</pose>
    </joint>

    <!-- Continuous revolute joint allowing the rotating arm to spin around the mast (Z-axis). -->
    <joint name="mast_to_arm_joint" type="revolute">
      <parent>central_mast</parent>
      <child>rotating_arm</child>
      <pose>0 0 -0.25 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14159265</lower>
          <upper>3.14159265</upper>
          <effort>10.0</effort>
          <velocity>2.0</velocity>
        </limit>
      </axis>
      <dynamics>
        <friction>0.5</friction>
        <damping>0.1</damping>
        <spring_reference>0</spring_reference>
        <spring_stiffness>0</spring_stiffness>
      </dynamics>
    </joint>

    <!-- Fixed joint attaching the banner to the rotating arm. -->
    <joint name="arm_to_banner_joint" type="fixed">
      <parent>rotating_arm</parent>
      <child>banner_panel</child>
      <pose>0 0 0.2 0 0 0</pose>
    </joint>
  </model>
</sdf>

<?xml version="1.0"?>
<model>
  <name>bird_motion_sprinkler</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>Takudzwa Magwenzi</name>
    <email>takudzwamagwenzi01@gmail.com</email>
  </author>

  <description>
    A motion-activated water sprinkler bird deterrent for Gazebo Classic 11 and ROS 2.
    The model includes a sensor base, fixed support stem, and a rotating nozzle head.
    Ideal for simulating active water-based deterrent systems in outdoor environments.
  </description>
</model>
